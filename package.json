{
  "name": "searchx-site",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run web/build/cli.js && bun x pagefind --site web/dist",
    "test": "bun test",
    "serve": "bun x pagefind --site web/dist && python3 -m http.server 8080 --directory web/dist",
    "build:worker": "bun build services/intake-worker/src/index.js --outfile services/intake-worker/dist/worker.js --format esm",
    "runner": "bun run services/runner/src/index.js",
    "runner:now": "launchctl kickstart gui/$(id -u)/com.searchx.runner",
    "runner:log": "tail -n 80 \"$HOME/Library/Logs/searchx-runner/runner.log\""
  },
  "devDependencies": {
    "gray-matter": "^4.0.3",
    "pagefind": "^1.1.0"
  },
  "dependencies": {
    "nodemailer": "^8.0.10"
  }
}
